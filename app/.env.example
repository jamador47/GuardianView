# GuardianView Environment Configuration
# Copy this file to .env and fill in your values

# === Required: Choose ONE authentication method ===

# Option A: Gemini API Key (for development)
GOOGLE_API_KEY=your-gemini-api-key-here

# Option B: Vertex AI (for production / Google Cloud deployment)
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# === GuardianView Settings ===

# Model to use (default: native audio for voice interaction)
GUARDIANVIEW_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Active safety profile: workshop, kitchen, or clinical
SAFETY_PROFILE=workshop

# Alert language: English, Spanish, French, Portuguese, German, Chinese, Japanese
ALERT_LANGUAGE=English

# === Email Notifications (Optional) ===

# Email address to receive safety incident alerts
EMAIL_RECIPIENT=your-email@example.com

# Email sender address (can be anything)
EMAIL_SENDER=guardianview@noreply.com

# SMTP Server Configuration
# For Gmail: Use smtp.gmail.com with port 587
# For other providers, check their SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SMTP Credentials
# For Gmail: Use your email and an App Password (not your regular password)
# Generate App Password at: https://myaccount.google.com/apppasswords
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# === Firebase Configuration (Optional) ===

# Path to Firebase service account credentials JSON file
# Download from: Firebase Console > Project Settings > Service Accounts > Generate new private key
#
# If the JSON file is in the same folder as .env (app/ folder):
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
#
# Or use an absolute path:
# FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json
#
# Or relative to project root:
# FIREBASE_CREDENTIALS_PATH=../firebase-credentials.json
